{
  "name": "WAACT Online Demo",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [8000, 3001],
  "portsAttributes": {
    "8000": {
      "label": "WAACT Dashboard",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "3001": {
      "label": "WhatsApp Connector Internal",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },
  "postCreateCommand": "bash scripts/codespaces_setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
