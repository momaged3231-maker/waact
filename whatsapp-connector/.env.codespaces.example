# WAACT WhatsApp Connector for Codespaces Online Demo
# Copy to whatsapp-connector/.env inside Codespaces and keep PORT 3001 private.

BACKEND_URL=http://127.0.0.1:8000
WEBHOOK_SECRET=change-this-and-match-backend
CONNECTOR_API_KEY=change-this-internal-connector-key
HOST=127.0.0.1
PORT=3001
LOGOUT_ON_SHUTDOWN=false
