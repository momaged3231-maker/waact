# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Database
DATABASE_URL=sqlite:///./waact.db

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIR=../chroma_db
CHROMA_COLLECTION=knowledge_base

# WhatsApp Connector
WHATSAPP_CONNECTOR_URL=http://localhost:3001
WHATSAPP_WEBHOOK_SECRET=waact-secret-change-me
WHATSAPP_CONNECTOR_API_KEY=connector-internal-secret-change-me

# App
APP_MODE=isp
APP_URL=http://localhost:8000
SECRET_KEY=change-this-in-production
DEBUG=true

# Optional dashboard auth
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-password
AUTH_ROLE=admin

# AI Settings
MAX_RESPONSE_TOKENS=500
TEMPERATURE=0.3

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=5

# Scheduling
REPORT_HOUR=8
FOLLOWUP_HOUR=10
