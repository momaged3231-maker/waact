# WAACT Online Demo on GitHub Codespaces + Supabase
# Copy to backend/.env inside Codespaces and fill real secrets there only.

APP_MODE=isp
APP_URL=https://YOUR-VERCEL-DEMO.vercel.app
SECRET_KEY=change-this-to-a-long-random-value
DEBUG=false

AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-strong-password
AUTH_ROLE=admin

# Supabase Transaction Pooler/Session Pooler URL. Use sslmode=require.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:6543/postgres?sslmode=require

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=knowledge_base

# Connector stays private inside the Codespace.
WHATSAPP_CONNECTOR_URL=http://127.0.0.1:3001
WHATSAPP_WEBHOOK_SECRET=change-this-and-match-connector
WHATSAPP_CONNECTOR_API_KEY=change-this-internal-connector-key

MAX_RESPONSE_TOKENS=500
TEMPERATURE=0.3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=5
REPORT_HOUR=8
FOLLOWUP_HOUR=10
